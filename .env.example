# =============================================================
# CodeCompass - Environment Variables Template
# Generated by IBM watsonx.ai (Bob) | IBM Bob Dev Day Hackathon
# Copy this file to .env and fill in your actual values
# =============================================================

# IBM watsonx.ai API Key (required)
# Get from: cloud.ibm.com → Manage → Access (IAM) → API keys
WATSONX_API_KEY=your-ibm-cloud-api-key-here

# IBM watsonx.ai Project ID (required)
# Get from: dataplatform.cloud.ibm.com → Your Project → Manage → General
WATSONX_PROJECT_ID=your-watsonx-project-id-here

# GitHub Personal Access Token (optional but recommended)
# Increases API rate limit from 60 to 5000 requests/hour
# Get from: github.com → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=your-github-token-here
